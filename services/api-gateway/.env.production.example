# Server config
PORT=3001
NODE_ENV=production
ALLOWED_ORIGINS=http://localhost:3000

# Services - Docker Compose (services in containers)
USER_SERVICE_BASE_URL=http://user-service:5001
CHAT_SERVICE_BASE_URL=http://chat-service:5002

# Database
POSTGRES_PASSWORD=supersecretpassword

# Auth
JWT_SECRET=your-jwt-secret
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=your-refresh-token-secret
REFRESH_TOKEN_EXPIRES_IN=30d